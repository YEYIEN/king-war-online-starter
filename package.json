{
  "name": "king-war-online-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev -- --host 0.0.0.0",
    "build": "cd client && npm run build",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "express": "^4.18.3",
    "socket.io": "^4.7.5",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}